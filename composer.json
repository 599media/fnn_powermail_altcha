{
	"name": "fnn/fnn-powermail-altcha",
	"type": "typo3-cms-extension",
	"description": "Altcha Captcha for Powermail - Accessible and GDPR compliant proof-of-work (pow) captcha for powermail, no external service required",
	"keywords": [
		"TYPO3",
		"gdpr"
	],
	"homepage": "https://599media.de",
	"license": "MIT",
	"require": {
		"typo3/cms-core": ">= 11.5.0 <= 13.4.99",
		"typo3/cms-extbase": ">= 10.4.0 <= 13.4.99",
		"in2code/powermail": ">=8.5.1",
		"php": ">= 8.2 <= 8.4",
		"altcha-org/altcha": "1.3.1"
	},
	"require-dev": {
		"typo3/cms-composer-installers": "^3.1.3 || 4.0.0-RC1 || ^5.0",
		"phpstan/phpstan": "^2.1"
	},
	"replace": {
		"typo3-ter/fnn-powermail-altcha": "self.version"
	},
	"config": {
		"allow-plugins": {
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		},
		"bin-dir": ".Build/bin",
		"lock": false,
		"sort-packages": true,
		"vendor-dir": ".Build/vendor"
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "fnn_powermail_altcha",
			"app-dir": ".Build",
			"web-dir": ".Build/Web"
		}
	},
	"autoload": {
		"psr-4": {
			"Fnn\\FnnPowermailAltcha\\": "Classes"
		}
	},
	"minimum-stability": "alpha",
	"authors": [
		{
			"name": "599media DEV-Team",
			"email": "info@599media.de"
		}
	]
}
